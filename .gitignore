# Python build artefacts
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info/

# Virtual environments
.venv/
.python-version

# Jupyter
.ipynb_checkpoints/
Untitled*.ipynb
*-checkpoint.ipynb

# Local-only source material (DO NOT commit to public CorpusAnalysis repo)
2025-WinterSchool/
Corpus Analysis Masterclass 2025.pdf
Corpus Analysis Masterclass 2025.pptx
carpentriesCollabLessonTraining.html

# Hard rule: NEVER commit LIWC dictionaries in any language (commercial, non-redistributable)
# See .notes/feedback_liwc-dictionary-handling.md
liwcdict.dic
LIWC*.dic
LIWC*.dict
liwc*.dic
liwc*.dict

# Editor / OS junk
.vscode/
.idea/
.DS_Store
Thumbs.db
*.swp
*~

# Claude Code local session state (per-checkout, never shared)
.claude/

# Build outputs (we want sources tracked, slide HTML built by CI)
_site/
_build/
slides/*.slides.html
slides/reveal.js/

# Paper discussion notes (local research artefacts, not student-facing)
docs/papers/

# Code-along dev sandbox: preserved on the code-along-dev branch, never on main
scratch/

# corpus_tools.py: the repo-root file is the single tracked source. The copies
# beside each notebook are generated by tools/sync_corpus_tools.py -- not tracked.
day-*/corpus_tools.py

# Slide + QA build outputs (regenerated by tools/render_slides.py; CI builds the
# public decks). Sources are the .ipynb; these are not tracked.
day-*/*.slides.html
day-*/*.slides.pdf
day-*/*.qa.md
